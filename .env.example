# Vault connection — the only secrets stored outside Vault in dev mode.
# VAULT_ADDR must point to localhost for local development (pipeline + direct API dev).
# Docker services that need the internal hostname hardcode vault:8200 themselves.
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=dev-root-token

# API keys — read by vault-seed at `docker compose run --rm vault-seed` to populate Vault.
# After seeding, the app and pipeline both read these from Vault, not from here directly.
VOYAGE_API_KEY=pa-xxx
ANTHROPIC_API_KEY=ant-sk-xxx
